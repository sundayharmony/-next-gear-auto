# Copy this file to local.properties (gitignored) and edit paths for your machine.
#
#   copy local.properties.example local.properties
#
# Example Windows:
sdk.dir=C\:\\Users\\YourName\\AppData\\Local\\Android\\Sdk

# Required for a PHYSICAL device (not the emulator). Find IP with: ipconfig
# Then: npm run dev:lan  (from the NGA website repo root)
ngaDebugApiUrl=http://192.168.1.100:3000

# Or use production without local dev:
# ngaDebugApiUrl=https://rentnextgearauto.com
