# Copy to .env.local and fill in values for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Auth (required for staff/owner JWT sessions)
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# Google Maps (optional — address autocomplete, fleet maps)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_SERVER_KEY=

# Staff messaging feature flags
FF_STAFF_MESSAGING_ENABLED=false
FF_STAFF_MESSAGING_EMAIL_ENABLED=false
NEXT_PUBLIC_FF_STAFF_MESSAGING_EMAIL_ENABLED=false
FF_STAFF_MESSAGING_PUSH_ENABLED=false

# Web push (optional)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# Turo webhook (production)
TURO_WEBHOOK_SECRET=

# Cron jobs (Vercel)
CRON_SECRET=

# One-time admin bootstrap (development only; production requires ALLOW_SETUP_ADMIN=true)
# ADMIN_PASSWORD=
# ALLOW_SETUP_ADMIN=false

# Upstash Redis — REQUIRED on Vercel production (see docs/vercel-upstash-setup.md)
# Optional locally (in-memory fallback when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
